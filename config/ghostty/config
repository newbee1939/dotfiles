# -----------------------------------------------------------------------------
# Zellij (Terminal Multiplexer) Settings
# -----------------------------------------------------------------------------

# 左のOptionキーをAltキーとして扱う設定
# これにより、Zellijでのペイン操作 (Option + 矢印/hjkl) が可能になります
macos-option-as-alt = left

# [操作メモ]
# 移動: Option + h(左) j(下) k(上) l(右)
# 増やす: Option + n(右に新規)

# -----------------------------------------------------------------------------
# Appearance (見た目)
# -----------------------------------------------------------------------------

# 背景を半透明にする (1.0 = 不透明, 0.0 = 完全透明)
background-opacity = 0.93

# 背景のぼかし。半透明時に後ろのウィンドウを軽くぼかして視認性を保つ (macOS のみ)
background-blur = 20
